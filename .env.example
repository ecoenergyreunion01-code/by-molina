# Configuration Canapé & Vous
# Dupliquez ce fichier en .env.local et remplissez vos clés

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=votre_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=votre_token

# Meilisearch
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=votre_cle_api

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=votre_cle_publiable
STRIPE_SECRET_KEY=votre_cle_secrete

# Resend (emails)
RESEND_API_KEY=re_votre_cle_api
CONTACT_EMAIL=votre@email.com

# URL du site
NEXT_PUBLIC_URL=http://localhost:3001
